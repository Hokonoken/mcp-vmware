# Copy to .vcenter.env (chmod 600) — direct mode — or to ~/VMware/.vcenter.env
# on the jump host. Never commit the real file.
VC_HOST=vcenter.example.com
VC_USER=svc-mcp@example.com
VC_PASS=changeme

# MCP server role: viewer (default) | operator | vm_admin | infra_admin
# See docs/roles.md for the permission groups.
MCP_VMWARE_ROLE=viewer
