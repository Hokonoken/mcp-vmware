# A copier sur la machine rebond dans ~/VMware/.vcenter.env (chmod 600).
# Ne jamais committer le fichier reel.
VC_HOST=vcenter.example.com
VC_USER=svc-mcp@example.com
VC_PASS=changeme

# Role du serveur MCP : viewer (defaut) | operator | vm_admin | infra_admin
# Voir docs/roles.md pour le detail des groupes de droits.
MCP_VMWARE_ROLE=viewer
